{
  "name": "@fastxyz/skill-benchmark",
  "version": "0.1.0",
  "description": "Generic SDK/MCP skill documentation benchmark framework",
  "type": "module",
  "bin": {
    "skill-benchmark": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "mock-repos/"
  ],
  "scripts": {
    "benchmark": "tsx src/cli.ts run",
    "dev": "tsx src/cli.ts",
    "optimize": "tsx src/optimizer/main.ts",
    "materialize:mock": "tsx src/optimizer/materialize-mock-repo.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx tests/smoke-code.ts && tsx tests/smoke-sdk-python.ts && tsx tests/smoke-sdk-rust.ts && tsx tests/smoke-cli.ts && tsx tests/smoke-mcp.ts && tsx tests/smoke-llm.ts && tsx tests/smoke-optimize.ts && tsx tests/smoke-mock-repos.ts"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.66.1",
    "@mariozechner/pi-ai": "^0.66.1",
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.24.7"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
