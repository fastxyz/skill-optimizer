{
  "benchmarkConfig": "./benchmark.config.json",
  "targetRepo": {
    "path": ".",
    "surface": "mcp",
    "allowedPaths": [
      "src",
      "docs",
      "README.md",
      "SKILL.md",
      "tools.json"
    ],
    "validation": [
      "node ./scripts/validate.mjs"
    ],
    "requireCleanGit": true
  },
  "optimizer": {
    "maxIterations": 5,
    "stabilityWindow": 2,
    "minOverallPassDelta": 0.01,
    "taskGeneration": {
      "enabled": false,
      "maxGenerated": 10,
      "seed": 1
    }
  },
  "mutation": {
    "provider": "openai",
    "model": "gpt-4o",
    "thinkingLevel": "medium",
    "apiKeyEnv": "OPENAI_API_KEY"
  }
}
