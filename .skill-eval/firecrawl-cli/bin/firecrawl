#!/usr/bin/env node
import { appendFileSync, mkdirSync, writeFileSync } from 'node:fs';
import { dirname, resolve } from 'node:path';

const args = process.argv.slice(2);
const workDir = process.env.WORK || process.cwd();

if (args.includes('--help') || args[0] === 'help') {
  console.log('firecrawl <search|scrape|map|crawl|parse> [options]');
  process.exit(0);
}

if (args[0] === '--status' || args[0] === 'status') {
  console.log('🔥 firecrawl cli v1.14.8');
  console.log('● Authenticated via FIRECRAWL_API_KEY');
  console.log('Concurrency: 0/100 jobs');
  console.log('Credits: 500000 remaining');
  process.exit(0);
}

appendFileSync(resolve(workDir, 'firecrawl-calls.ndjson'), `${JSON.stringify({ args })}\n`, 'utf-8');

const output = flagValue(args, '-o') ?? flagValue(args, '--output');
if (output) {
  const outputPath = output.startsWith('/') ? output : resolve(workDir, output);
  mkdirSync(dirname(outputPath), { recursive: true });
  writeFileSync(outputPath, fixtureOutput(args), 'utf-8');
}

console.log(fixtureOutput(args));

function flagValue(values, flag) {
  const index = values.indexOf(flag);
  return index >= 0 ? values[index + 1] : undefined;
}

function fixtureOutput(values) {
  const command = values[0];
  if (command === 'search') {
    return JSON.stringify({ data: { web: [{ title: 'Browser automation guide', url: 'https://example.com/browser-automation', markdown: 'Full browser automation content.' }] } }, null, 2);
  }
  if (command === 'map') {
    return JSON.stringify({ links: ['https://docs.example.com/docs/api/authentication'] }, null, 2);
  }
  if (command === 'crawl') {
    return JSON.stringify({ pages: [{ url: 'https://docs.example.com/docs/start', markdown: 'Docs page content.' }] }, null, 2);
  }
  if (command === 'parse') {
    return '# Parsed Report\n\nFixture parsed markdown from report.pdf.\n';
  }
  return '# Scraped Page\n\nFixture scraped markdown content.\n';
}
